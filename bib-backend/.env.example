# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google AI Studio
GOOGLE_AI_API_KEY=AIzaSy...
GOOGLE_AI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash   # lista ordenada por prioridade; adicionar mais modelos separados por vírgula

# OpenRouter
OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_MODELS=deepseek/deepseek-v4-flash
OPENROUTER_MAX_TOKENS=65536

# Geracao IA por secoes/modulos
SECTION_GENERATION_ENABLED=true
SECTION_GENERATION_FORMATS=html,whitelabel_json
SECTION_TARGET_WORD_MULTIPLIER=1
SECTION_MIN_ACCEPTANCE_RATIO=0.9
SECTION_MAX_ACCEPTANCE_RATIO=1.1
SECTION_GENERATION_CONCURRENCY=5
SECTION_REPAIR_ATTEMPTS=2
SECTION_FINAL_EXPANSION_ROUNDS=3
SECTION_FINAL_EXPANSION_SECTIONS=4

# WordPress
WP_BASE_URL=https://teu-site.pt
WP_SECRET=your_wp_secret_here

# Fila — Concorrência por Modo
# AI deve ficar 1 para processar templates IA como fila real.
# O paralelismo das secoes do mesmo template e controlado por SECTION_GENERATION_CONCURRENCY.
QUEUE_CONCURRENCY_AI=1
QUEUE_CONCURRENCY_TEMPLATE=8
QUEUE_CONCURRENCY_LIBRARY=10
